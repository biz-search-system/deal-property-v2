{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "generate-sample": "pnpx @better-auth/cli generate --output ../db/schemas/auth.ts --yes",
    "generate-auth-schema": "pnpx @better-auth/cli@latest generate --config ./src/auth.ts --output ../drizzle/schemas/auth.ts --yes",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/auth-client.ts",
      "default": "./src/auth-client.ts"
    },
    "./handlers": {
      "types": "./src/handlers.ts",
      "default": "./src/handlers.ts"
    },
    "./cookies": {
      "types": "./src/cookies.ts",
      "default": "./src/cookies.ts"
    }
  },
  "dependencies": {
    "@workspace/drizzle": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/ui": "workspace:*",
    "@workspace/utils": "workspace:*",
    "better-auth": "^1.4.5",
    "drizzle-orm": "^0.44.7",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^5.9.3"
  }
}
