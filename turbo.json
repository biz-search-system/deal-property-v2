{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "TURSO_DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "TURSO_AUTH_TOKEN",
        "RESEND_API_KEY",
        "EDGE_CONFIG"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate-auth-schema": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
