{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "TURSO_DATABASE_URL",
        "TURSO_AUTH_TOKEN",
        "BETTER_AUTH_SECRET",
        "RESEND_API_KEY",
        "RESEND_DOMAIN",
        "EDGE_CONFIG",
        "NODE_ENV",
        "CLOUDFLARE_S3_ENDPOINT",
        "CLOUDFLARE_S3_ACCESS_KEY_ID",
        "CLOUDFLARE_S3_SECRET_ACCESS_KEY",
        "CLOUDFLARE_S3_BUCKET",
        "CLOUDFLARE_S3_PUBLIC_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate-auth-schema": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "gm": {
      "cache": false,
      "env": ["TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN"]
    },
    "migrate": {
      "cache": false,
      "env": ["TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN"]
    }
  }
}
